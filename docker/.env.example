# Environment Configuration Template
# Copy this file to .env and fill in the values

# ============================================
# Application
# ============================================
APP_NAME=MyRag
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-this-to-a-secure-random-string-at-least-32-characters

# ============================================
# API Configuration
# ============================================
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
API_KEY_HEADER=X-API-Key

# ============================================
# PostgreSQL Database
# ============================================
DATABASE_URL=postgresql+asyncpg://myrag:myrag@localhost:5432/myrag
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ============================================
# Milvus Vector Database
# ============================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_PREFIX=myrag

# ============================================
# Elasticsearch
# ============================================
ES_HOSTS=http://localhost:9200
ES_INDEX_PREFIX=myrag
ES_USER=
ES_PASSWORD=

# ============================================
# Neo4j Knowledge Graph
# ============================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123
NEO4J_DATABASE=neo4j

# ============================================
# Redis Cache
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# Celery Task Queue
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================
# Embedding Model (BGE-M3)
# ============================================
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_MODEL_PATH=
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIMENSION=1024

# ============================================
# Reranker Model (Jina-Rerank)
# ============================================
RERANKER_MODEL=jinaai/jina-reranker-v2-base-multilingual
RERANKER_MODEL_PATH=
RERANKER_DEVICE=cuda
RERANKER_TOP_K=5

# ============================================
# LLM Provider
# ============================================
# Options: ollama, vllm, openai, mock
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:14b
LLM_API_URL=http://localhost:11434
LLM_API_KEY=
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# ============================================
# Document Processing
# ============================================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=104857600
ALLOWED_EXTENSIONS=pdf,docx,doc,txt,html,md

# ============================================
# Semantic Chunking
# ============================================
CHUNK_MIN_SIZE=100
CHUNK_MAX_SIZE=1000
CHUNK_OVERLAP_MIN=10
CHUNK_OVERLAP_MAX=250
SEMANTIC_BOUNDARY_THRESHOLD=0.5

# ============================================
# Retrieval Settings
# ============================================
RETRIEVAL_TOP_K=50
COARSE_RANK_TOP_K=20
FINAL_TOP_K=5

# ============================================
# Fusion Algorithm
# ============================================
FUSION_K=60
FUSION_ALPHA=0.3
FUSION_BETA=0.2

# ============================================
# Confidence Scoring
# ============================================
CONFIDENCE_THRESHOLD=0.6
LOW_CONFIDENCE_FALLBACK=true

# ============================================
# Tiered Storage
# ============================================
HOT_TIER_DAYS=30
WARM_TIER_DAYS=90
TIER_PROMOTION_THRESHOLD=10
TIER_DEMOTION_THRESHOLD=1

# ============================================
# Caching
# ============================================
QUERY_CACHE_TTL=300
VECTOR_CACHE_TTL=1800
SESSION_CACHE_TTL=3600

# ============================================
# Monitoring
# ============================================
METRICS_ENABLED=true
METRICS_PORT=9090
TRACING_ENABLED=false
TRACING_SAMPLE_RATE=0.1

# ============================================
# Performance Targets
# ============================================
MAX_RETRIEVAL_LATENCY_MS=300
MAX_CONCURRENT_USERS=50